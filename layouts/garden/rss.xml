{{- $pctx := . -}}
{{- if .IsHome -}}{{ $pctx = .Site }}{{- end -}}
{{- $pages := slice -}}
{{- if or $.IsHome $.IsSection -}}{{ $pages = $pctx.RegularPages -}}{{- else -}}{{ $pages = $pctx.Pages -}}{{- end -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}{{ $pages = $pages | first $limit -}}{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Garden — Abdelrahman Madkour</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with .Description }}{{ . }}{{ else }}Concept and media notes from a3madkour's garden.{{ end }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.Language.Lang }}</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    {{ range $pages }}
    {{- if not .Draft -}}
    {{- $lm := .Params.last_modified -}}
    {{- $when := .Date -}}
    {{- if $lm -}}
      {{- if reflect.IsMap $lm -}}{{- /* unlikely */ -}}
      {{- else if (strings.Contains (printf "%T" $lm) "string") -}}
        {{- $when = time.AsTime (printf "%sT00:00:00Z" $lm) -}}
      {{- else -}}
        {{- $when = $lm -}}
      {{- end -}}
    {{- end -}}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ $when.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ with .Params.summary }}{{ . | html }}{{ else }}{{ .Summary | plainify | html }}{{ end }}</description>
    </item>
    {{- end -}}
    {{ end }}
  </channel>
</rss>
